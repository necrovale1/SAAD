<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="SAAD.FaltasPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="FaltasPage"
    BindingContext="{x:Reference local:Faltas}">


    <VerticalStackLayout Padding="10,0" Spacing="15">

        <Label
            FontAttributes="Bold"
            FontSize="Header"
            HorizontalOptions="Center"
            Text="Página de Faltas"
            TextColor="{DynamicResource Special}"
            VerticalOptions="Center" />
        <Label
            FontSize="Large"
            HorizontalOptions="Center"
            Text="Materia"
            TextColor="{DynamicResource Special}"
            VerticalOptions="Center" />
        <Label
            FontAttributes="Bold"
            FontSize="Large"
            HorizontalOptions="Center"
            Text="{Binding Materia}"
            TextColor="{DynamicResource Input}"
            VerticalOptions="Center" />
        <Label
            FontSize="Large"
            HorizontalOptions="Center"
            Text="Falta"
            TextColor="{DynamicResource Special}"
            VerticalOptions="Center" />
        <Label
            FontAttributes="Bold"
            FontSize="Large"
            HorizontalOptions="Center"
            Text="{Binding Falta}"
            TextColor="{DynamicResource Input}"
            VerticalOptions="Center" />
        <Label
            FontSize="Large"
            HorizontalOptions="Center"
            Text="Presença"
            TextColor="{DynamicResource Special}"
            VerticalOptions="Center" />
        <Label
            FontAttributes="Bold"
            FontSize="Large"
            HorizontalOptions="Center"
            Text="{Binding Presenca}"
            TextColor="{DynamicResource Input}"
            VerticalOptions="Center" />
        <Button
            x:Name="btnVoltar"
            BackgroundColor="{DynamicResource Special}"
            Clicked="btnVoltar_Clicked"
            FontAttributes="Bold"
            FontSize="Large"
            MaximumWidthRequest="300"
            Text="Voltar" />
    </VerticalStackLayout>
</ContentPage>