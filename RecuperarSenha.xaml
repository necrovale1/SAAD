<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="SAAD.RecuperarSenha"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Recuperar Senha">
    <VerticalStackLayout
        Padding="30"
        Spacing="15"
        VerticalOptions="Center">
        <Label
            FontAttributes="Bold"
            FontSize="24"
            HorizontalOptions="Center"
            Text="Recuperar sua senha" />
        <Label
            HorizontalOptions="Center"
            HorizontalTextAlignment="Center"
            Text="Digite seu e-mail para receber o link de recuperação." />
        <Entry
            x:Name="EmailEntry"
            Keyboard="Email"
            Placeholder="seu.email@exemplo.com" />
        <Button Clicked="OnEnviarClicked" Text="Enviar Link" />
        <Button
            BackgroundColor="Transparent"
            Clicked="OnVoltarClicked"
            Text="Voltar"
            TextColor="{AppThemeBinding Light=Gray,
                                        Dark=White}" />
    </VerticalStackLayout>
</ContentPage>