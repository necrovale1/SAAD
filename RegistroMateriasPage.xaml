<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="SAAD.RegistroMateriasPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Registrar Nova Matéria">
    <VerticalStackLayout Padding="20" Spacing="10">
        <Label Text="Nome da Matéria" />
        <Entry x:Name="NomeEntry" Placeholder="Ex: Cálculo I" />

        <Label Text="Descrição" />
        <Editor
            x:Name="DescricaoEditor"
            HeightRequest="100"
            Placeholder="Descreva a matéria" />

        <Label Text="Categoria" />
        <Entry x:Name="CategoriaEntry" Placeholder="Ex: Ciências Exatas" />

        <Button Clicked="OnSalvarClicked" Text="Salvar Matéria" />
        <Button Clicked="OnVoltarClicked" Text="Voltar" />
    </VerticalStackLayout>
</ContentPage>