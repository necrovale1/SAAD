<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="SAAD.HomePage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Início">
    <ScrollView>
        <VerticalStackLayout Padding="30" Spacing="20">
            <Label
                FontAttributes="Bold"
                FontSize="28"
                HorizontalOptions="Center"
                Text="Bem-vindo, aluno!" />

            <Button
                x:Name="btnMaterias"
                Margin="0,20,0,0"
                BackgroundColor="{DynamicResource Special}"
                Clicked="btnMaterias_Clicked"
                HeightRequest="50"
                Text="Abrir Matérias" />

            <Button
                x:Name="btnFaltas"
                BackgroundColor="{DynamicResource Special}"
                Clicked="btnFaltas_Clicked"
                HeightRequest="50"
                Text="Abrir Faltas" />

            <Button
                Margin="0,40,0,0"
                BackgroundColor="{DynamicResource Special}"
                Clicked="OnLogoutClicked"
                HeightRequest="50"
                Text="Sair"
                TextColor="White" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>