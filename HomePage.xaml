<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="SAAD.HomePage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="HomePage">
    <VerticalStackLayout Padding="10,10,10,10">
        <Label
            HorizontalOptions="Center"
            Text="Bem vindo, Aluno!"
            VerticalOptions="Center" />

        <Button
            x:Name="btnMaterias"
            BackgroundColor="{DynamicResource Special}"
            Clicked="btnMaterias_Clicked"
            FontAttributes="Bold"
            FontSize="Medium"
            MaximumWidthRequest="300"
            Text="Abrir Matérias" />

        <Button
            x:Name="btnFaltas"
            BackgroundColor="{DynamicResource Special}"
            Clicked="btnFaltas_Clicked"
            FontAttributes="Bold"
            FontSize="Medium"
            MaximumWidthRequest="300"
            Text="Abrir Faltas" />

    </VerticalStackLayout>
</ContentPage>