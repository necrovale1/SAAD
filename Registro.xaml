<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="SAAD.Registro"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Registro">
    <VerticalStackLayout
        HorizontalOptions="Center"
        Spacing="25"
        VerticalOptions="Center">

        <Label
            FontSize="22"
            HorizontalOptions="Center"
            SemanticProperties.HeadingLevel="Level1"
            Text="Página de Registro em Manutenção" />

        <Label
            FontSize="16"
            HorizontalOptions="Center"
            SemanticProperties.Description="Informação adicional sobre a manutenção"
            Text="Estamos trabalhando para trazer essa funcionalidade em breve!" />

        <Image
            MaximumHeightRequest="250"
            MaximumWidthRequest="250"
            Source="manutencao.png" />

    </VerticalStackLayout>
</ContentPage>