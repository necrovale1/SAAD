<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="SAAD.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:SAAD"
    Title="SAAD"
    Shell.FlyoutBehavior="Flyout">

    <Shell.TitleView>
        <HorizontalStackLayout
            HorizontalOptions="End"
            Spacing="10"
            VerticalOptions="End" />

    </Shell.TitleView>

    <TabBar>
        <Tab Title="Logout" Icon="enter.png">
            <ShellContent ContentTemplate="{DataTemplate local:MainPage}" Route="MainPage" />
        </Tab>

        <Tab Title="Home" Icon="home.png">
            <ShellContent ContentTemplate="{DataTemplate local:HomePage}" Route="HomePage" />
        </Tab>

        <Tab Title="Recuperar" Icon="key.png">
            <ShellContent ContentTemplate="{DataTemplate local:RecuperarSenha}" Route="RecuperarSenha" />
        </Tab>

        <Tab Title="Registro" Icon="user.png">
            <ShellContent ContentTemplate="{DataTemplate local:Registro}" Route="Registro" />
        </Tab>
    </TabBar>

    <ShellContent
        Title="Início"
        ContentTemplate="{DataTemplate local:HomePage}"
        Route="HomePage" />

</Shell>