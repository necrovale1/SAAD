<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="SAAD.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:SAAD"
    Shell.FlyoutBehavior="Flyout">

    <Shell.Resources>
        <Style TargetType="FlyoutItem">
            <Setter Property="Shell.TitleColor" Value="{StaticResource PageBackgroundColor}" />
        </Style>
    </Shell.Resources>

    <FlyoutItem Title="Matérias" Route="MateriasPage">
        <FlyoutItem.Icon>
            <FontImageSource
                FontFamily="MaterialOutlined"
                Glyph="{x:Static local:MaterialIconFont.Materias}"
                Color="Black" />
        </FlyoutItem.Icon>
        <ShellContent ContentTemplate="{DataTemplate local:MateriasPage}" />
    </FlyoutItem>

    <FlyoutItem Title="Faltas" Route="FaltasPage">
        <FlyoutItem.Icon>
            <FontImageSource
                FontFamily="MaterialOutlined"
                Glyph="{x:Static local:MaterialIconFont.Faltas}"
                Color="Black" />
        </FlyoutItem.Icon>
        <ShellContent ContentTemplate="{DataTemplate local:FaltasPage}" />
    </FlyoutItem>

    <FlyoutItem Title="Sair" Route="LogoutPage">
        <FlyoutItem.Icon>
            <FontImageSource
                FontFamily="MaterialOutlined"
                Glyph="{x:Static local:MaterialIconFont.Logout}"
                Color="Black" />
        </FlyoutItem.Icon>
        <ShellContent ContentTemplate="{DataTemplate local:LogoutPage}" />
    </FlyoutItem>

</Shell>