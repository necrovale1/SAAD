<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="SAAD.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:SAAD"
    Title="SAAD"
    Shell.FlyoutBehavior="Disabled">

    <Shell.TitleView>
        <HorizontalStackLayout
            HorizontalOptions="End"
            Spacing="10"
            VerticalOptions="End" />
    </Shell.TitleView>

    <TabBar>
        <Tab Title="Home" Icon="home.png">
            <ShellContent ContentTemplate="{DataTemplate local:HomePage}" Route="HomePage" />
        </Tab>
        <Tab Title="Matérias" Icon="book.png">
            <ShellContent ContentTemplate="{DataTemplate local:MateriasPage}" Route="MateriasPage" />
        </Tab>
        <Tab Title="Faltas" Icon="attendance.png">
            <ShellContent ContentTemplate="{DataTemplate local:FaltasPage}" Route="FaltasPage" />
        </Tab>
        <Tab Title="Logout" Icon="logout.png">
            <ShellContent ContentTemplate="{DataTemplate local:LogoutPage}" Route="LogoutPage" />
        </Tab>
    </TabBar>
</Shell>